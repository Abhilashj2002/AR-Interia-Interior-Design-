# Runtime
NODE_ENV=production
PAYMENT_SERVER_PORT=5175
JWT_SECRET=replace-with-a-long-random-secret

# Optional AI providers
PRO_ENGINE_KEY=
GEMINI_API_KEY=

# Razorpay (required only if Razorpay payments are enabled)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PhonePe (required only if PhonePe payments are enabled)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=
PHONEPE_ENV=UAT
PAYMENT_REDIRECT_BASE=https://your-frontend-domain/dashboard
PAYMENT_CALLBACK_BASE=https://your-backend-domain/api/payments/phonepe/callback

# Email (required only if invoice email sending is enabled)
EMAIL_ENABLED=false
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=
