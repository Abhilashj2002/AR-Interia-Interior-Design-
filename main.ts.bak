  border: 1px solid rgba(148, 163, 184, 0.3);
  background: rgba(15, 15, 35, 0.7);
  color: white;
}

        .portfolio-search - input::placeholder {
  color: rgba(226, 232, 240, 0.6);
}

        .portfolio-category - chips {
