  background: linear-gradient(135deg, #22d3ee, #a855f7);
}

        .portfolio-people - card {
  display: flex;
  gap: 1rem;
  padding: 1.5rem;
  border-radius: 1.5rem;
  border: 1px solid rgba(148, 163, 184, 0.2);
