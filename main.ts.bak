  background: rgba(15, 15, 35, 0.6);
  backdrop-filter: blur(10px);
}

        .portfolio-service {
  padding: 1.5rem;
  border-radius: 1.5rem;
  border: 1px solid rgba(168, 85, 247, 0.2);
  background: rgba(15, 15, 35, 0.6);
  display: flex;
