  font-size: 0.85rem;
  color: rgba(226, 232, 240, 0.7);
}

        .portfolio-showcase {
  margin-bottom: 2.5rem;
  padding: 1.5rem;
  border-radius: 1.5rem;
  border: 1px solid rgba(34, 211, 238, 0.2);
  background: rgba(15, 15, 35, 0.6);
  backdrop-filter: blur(12px);
}

        .portfolio-showcase - header {
